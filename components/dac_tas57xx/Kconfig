if DAC_TAS57XX

    choice TAS57XX_HYBRID_FLOW
        prompt "DSP hybrid flow configuration"
        default TAS57XX_HF1
        help
            Select which PurePath Console hybrid flow to load at boot.

        config TAS57XX_HF1
            bool "HF1 (tt_hf1)"
            help
                Load the HF1 hybrid flow configuration.

        config TAS57XX_HF6
            bool "HF6 (tt_hf6)"
            help
                Load the HF6 hybrid flow configuration.

    endchoice

    config TAS57XX_MAX_VOLUME
        int "Maximum DAC volume (dB)"
        range -100 0
        default -30
        help
            Maximum volume level in dB that corresponds to AirPlay volume 0 dB.
            The TAS57xx register range is 0 dB to -127 dB.
            A value of -30 means AirPlay full volume maps to -30 dB on the DAC.

endif # DAC_TAS57XX
